# ============================================
# EduMatrix 智教矩阵 - 环境变量配置
# 复制此文件为 .env（可选）
# 重要：API Key 现在可以在前端 Settings 页面配置
# 无需在 .env 中硬编码！
# ============================================

# ---- LLM 配置（仅在启动默认引擎时使用） ----
# 实际使用时，在浏览器中打开 /settings 页面配置即可
EDUMATRIX_LLM_PROVIDER=openai
EDUMATRIX_LLM_ENDPOINT=https://windhub.cc/v1/chat/completions
EDUMATRIX_LLM_API_KEY=
EDUMATRIX_LLM_MODEL=doubao-1-5-pro-32k-250115
EDUMATRIX_LLM_TEMPERATURE=0.3
EDUMATRIX_LLM_MAX_TOKENS=4096
EDUMATRIX_LLM_TIMEOUT=120

# ---- 并发控制 ----
EDUMATRIX_MAX_CONCURRENT_LLM=8
EDUMATRIX_LLM_RATE_LIMIT_RPM=120
EDUMATRIX_LLM_RATE_LIMIT_TPM=100000
EDUMATRIX_CIRCUIT_BREAKER_THRESHOLD=5
EDUMATRIX_CIRCUIT_BREAKER_WINDOW=60
EDUMATRIX_RETRY_MAX_ATTEMPTS=3
EDUMATRIX_REQUEST_QUEUE_SIZE=200

# ---- 嵌入配置（默认 hash，不需下载） ----
EDUMATRIX_EMBEDDING_PROVIDER=hash

# ---- 检索配置 ----
EDUMATRIX_TOP_K=6
EDUMATRIX_DEBATE_MIN_SCORE=0.42
EDUMATRIX_ALIGNMENT_THRESHOLD=0.65
EDUMATRIX_ROLLBACK_LIMIT=2

# ---- FAISS（默认关闭） ----
EDUMATRIX_USE_FAISS=0

# ---- 讯飞星火（备选 LLM） ----
SPARK_APP_ID=
SPARK_API_KEY=
SPARK_API_SECRET=

# ---- Authentication and safety ----
# Use a unique random value (at least 32 characters) in production.
EDUMATRIX_ENV=development
EDUMATRIX_AUTH_SECRET_KEY=
EDUMATRIX_AUTH_ALGORITHM=HS256
EDUMATRIX_AUTH_TOKEN_EXPIRE_MINS=1440
EDUMATRIX_DEMO_MODE=0
EDUMATRIX_MAX_UPLOAD_BYTES=20971520
# disabled = no Docker required; docker = enable isolated code execution
EDUMATRIX_SANDBOX_MODE=disabled
